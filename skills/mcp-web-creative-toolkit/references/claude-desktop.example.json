{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY"
      }
    },
    "clipia": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.clipia.ai/mcp",
        "--header",
        "Authorization: Bearer clipia_test_YOUR_KEY"
      ]
    },
    "chrome-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "http://127.0.0.1:12306/mcp"
      ]
    }
  }
}
